# ── API Bot (.env) ────────────────────────────────────────────────────
# This file configures the API bot (bot.py) — general assistant with tools.

# Get your Telegram bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Get your Anthropic API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Claude model to use (default: sonnet — auto-resolves to latest)
# Use bare aliases "fable" / "opus" / "sonnet" / "haiku" to always get the latest,
# or pin a specific id like "claude-sonnet-4-5-20250929".
CLAUDE_MODEL=sonnet

# GitHub personal access token for reading/writing repos
# Create one at https://github.com/settings/tokens with repo scope
GITHUB_TOKEN=

# Google Tasks, Calendar, Gmail — run `python setup_google.py` to get these
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional: Your timezone (default: UTC)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/London

# Optional: Daily briefing time (HH:MM in your timezone)
# Sends calendar + tasks summary to all allowed users
DAILY_BRIEFING_TIME=08:00

# Optional: OpenAI API key for voice transcription (Whisper)
OPENAI_API_KEY=

# Optional: MCP servers (JSON, Claude Desktop format)
# Stdio (local subprocess):
#   {"fetch": {"command": "uv", "args": ["tool", "run", "mcp-server-fetch", "--ignore-robots-txt"]}}
# Streamable HTTP (remote):
#   {"remote": {"url": "https://mcp.example.com/mcp", "headers": {"Authorization": "Bearer token"}}}
MCP_SERVERS=

# Optional: Restrict bot to specific Telegram user IDs (comma-separated)
# Leave empty to allow all users
ALLOWED_USER_IDS=

# Optional: Claude plan usage tracking (both bots)
# Get these cookie values from claude.ai after logging in, or use the
# browser extension Sync button (see CREDENTIALS_SYNC_TOKEN below).
CLAUDE_SESSION_KEY=
CLAUDE_ORG_ID=

# ── Agent Bot (.env.agent) ────────────────────────────────────────────
# The agent bot (bot_agent.py) needs a separate .env.agent file with:
#   TELEGRAM_BOT_TOKEN=<different-bot-token-from-botfather>
#   GITHUB_TOKEN=<same-github-token>
#   ALLOWED_USER_IDS=<same-user-ids>
#   CLAUDE_MODEL=opus               (default if omitted; "fable"/"opus"/"sonnet"/"haiku" auto-resolve to latest)
#   TIMEZONE=<optional-timezone>
#
# Optional: Credential sync from browser extension (enables /usage on mobile)
# The agent bot listens on CREDENTIALS_PORT for POSTs from the Chrome extension.
# Generate a random token: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   CREDENTIALS_PORT=8081
#   CREDENTIALS_SYNC_TOKEN=<random-secret>
#
# WARNING: Do NOT set ANTHROPIC_API_KEY in .env.agent!
# The agent bot uses Claude Code CLI which authenticates via Max plan
# (run `deploy.sh login` to set up). If ANTHROPIC_API_KEY is present,
# the CLI will use it instead, burning API credits.
